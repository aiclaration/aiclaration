# Environment Variables
# KEINE Secrets hier! Nutze Bitwarden CLI.
# Im Deployment (Hetzner + Coolify): als Environment Variables im Coolify-Dashboard setzen.
# WICHTIG: In Produktion MUESSEN alle drei BREVO_*-Vars gesetzt sein — fehlt eine,
# antwortet /api/subscribe bewusst mit HTTP 500 (kein stiller Erfolg, kein Datenverlust).

# Brevo (E-Mail-Provider)
# API Key: Dashboard > Settings > API Keys > Create a new API key
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx

# Brevo Kontaktliste fuer DOI-Subscriber
# Dashboard > Contacts > Lists > ID in der URL
BREVO_LIST_ID=2

# Template-ID fuer die DOI-Bestaetigungs-Mail
# Dashboard > Email Templates > ID
BREVO_DOI_TEMPLATE_ID=1

# Produktions-URL — Basis fuer den DOI-Redirect ({appUrl}/bestaetigt)
NEXT_PUBLIC_APP_URL=https://aiclaration.de
